{% if total == 0 or total == nil %}
<div class="layout layout--col layout--center gap--small">
  <span class="value value--large">No cards found</span>
  <span class="label">{{ error | default: "Check the set code in the plugin settings (scryfall.com/sets)" }}</span>
</div>
{% elsif two_up %}
<div class="layout layout--row layout--stretch gap--large">
  <div class="flex flex--col flex--center-y gap--small h--full stretch" style="min-width: 0">
    <div class="flex flex--center-y flex--center-x w--full stretch" style="min-height: 0">
      <img class="image image-dither" src="{{ card.img }}" style="max-height: 100%; width: auto" />
    </div>
    <div class="title title--small text--center w--full" data-clamp="1">{{ card.name }}</div>
    <div class="value value--xxsmall text--center w--full">{% if card.price_eur %}{{ card.price_eur }} &euro;{% else %}&mdash; &euro;{% endif %} &middot; {{ card.rarity | capitalize }}{% if card.pt != "" %} &middot; {{ card.pt }}{% endif %}</div>
  </div>
  <div class="flex flex--col flex--center-y gap--small h--full stretch" style="min-width: 0">
    <div class="flex flex--center-y flex--center-x w--full stretch" style="min-height: 0">
      <img class="image image-dither" src="{{ card_next.img }}" style="max-height: 100%; width: auto" />
    </div>
    <div class="title title--small text--center w--full" data-clamp="1">{{ card_next.name }}</div>
    <div class="value value--xxsmall text--center w--full">{% if card_next.price_eur %}{{ card_next.price_eur }} &euro;{% else %}&mdash; &euro;{% endif %} &middot; {{ card_next.rarity | capitalize }}{% if card_next.pt != "" %} &middot; {{ card_next.pt }}{% endif %}</div>
  </div>
</div>
{% else %}
<div class="layout layout--row layout--stretch gap--large" style="flex: 1 1 auto; min-height: 0">
  <div class="flex flex--center-y h--full">
    <img class="image image-dither" src="{{ card.img }}" style="max-height: 100%; width: auto" />
  </div>
  <div class="flex flex--col gap--xsmall h--full stretch lg:pt--10 lg:pr--16 lg:pb--10" style="min-width: 0; min-height: 0; align-items: flex-start">

    <div class="w--full">
      <div class="flex flex--center-y w--full">
        <span class="title title--large stretch" data-clamp="1" style="min-width: 0">{{ card.name }}</span>
        {% if card.mana != "" %}<span class="value value--small value--tnums no-shrink">{{ card.mana }}</span>{% endif %}
      </div>
      <div class="value value--xsmall lg:mt--5" data-clamp="1">{{ card.type }}</div>
    </div>

    <div class="w--full lg:mt--16">
      {% if card.keywords != "" %}
      <div class="title title--small">{{ card.keywords }}</div>
      {% endif %}
      <div class="value value--xsmall lg:hidden" style="white-space: pre-line">{{ card.text }}</div>
      <div class="value value--xsmall hidden lg:block" style="white-space: pre-line">{{ card.text_lg }}</div>
      {% if card.flavor != "" %}
      <div class="value value--xxsmall" style="font-style: italic">{{ card.flavor }}</div>
      {% endif %}
      {% if card.pt != "" %}
      <div class="w--full text--right pr--5">
        <span class="value lg:value--large value--tnums">{{ card.pt }}</span>
      </div>
      {% endif %}
    </div>

    <div class="stretch"></div>

    <div class="w--full">
      {% if card.legal != "" %}
      <div class="value value--xxsmall block">Legal: {{ card.legal }}</div>
      {% endif %}
      <div class="value value--xxsmall block">{{ card.rarity | capitalize }} #{{ card.cn }}{% if card.price_eur_foil %} &middot; Foil {{ card.price_eur_foil }} &euro;{% endif %}{% if card.reprint %} &middot; Reprint{% endif %}</div>
      <div class="value value--xxsmall block">Art: {{ card.artist }}</div>

      <div class="flex w--full lg:mt--16" style="align-items: flex-end">
        <div class="flex gap--large stretch" style="min-width: 0; align-items: flex-end">
          <div class="flex flex--col no-shrink">
            {% if card.price_eur %}
            <span class="value value--tnums">{{ card.price_eur }} &euro;</span>
            <span class="value value--xxsmall">Cardmarket</span>
            {% else %}
            <span class="value value--small">&mdash;</span>
            <span class="value value--xxsmall">Price from {{ release | date: "%b %d" }}</span>
            {% endif %}
          </div>
          {% if card.edhrec_fmt != "" %}
          <div class="flex flex--col no-shrink">
            <span class="value value--tnums">{{ card.edhrec_fmt }}</span>
            <span class="value value--xxsmall">EDHREC</span>
          </div>
          {% endif %}
        </div>
        {% if card.buy_url != "" %}
        <div class="hidden lg:block no-shrink w--[110px] h--[110px]">{{ card.buy_url | qr_code }}</div>
        {% endif %}
      </div>

      <div class="progress-bar progress-bar--xsmall hidden lg:block w--full lg:mt--16">
        {%- comment -%} Inline width is TRMNL's own documented progress-bar pattern; a Liquid-computed percentage cannot be a class. {%- endcomment -%}
        <div class="track"><div class="fill" style="width: {{ pos | times: 100 | divided_by: total }}%"></div></div>
      </div>
    </div>

  </div>
</div>
{% endif %}

<div class="title_bar">
  <span class="title">{{ set_name }}</span>
  {% if card_next and two_up != true %}
  {%- comment -%} .title carries the bar's optical padding-top; a plain value span sits visibly too high {%- endcomment -%}
  <span class="title stretch text--center" style="min-width: 0; overflow: hidden; text-overflow: ellipsis">Next: {{ card_next.name }}{% if card_next.price_eur %} ({{ card_next.price_eur }} &euro;){% endif %}</span>
  {% endif %}
  <span class="instance" style="flex: 0 0 auto">Card {{ pos }}/{{ total }}</span>
</div>
