<div class="layout layout--row layout--stretch gap--medium">
  <div style="height: 100%; display: flex; align-items: center">
    <img class="image image-dither" src="{{ card.img }}" style="max-height: 100%; width: auto" />
  </div>
  <div class="flex--col gap--xsmall" style="flex: 1; min-width: 0; height: 100%; justify-content: center">
    <span class="title title--small" data-clamp="2">{{ card.name }}</span>
    <span class="label label--small" data-clamp="2">{{ card.type }}{% if card.pt != "" %} &middot; {{ card.pt }}{% endif %}{% if card.mana != "" %} &middot; {{ card.mana }}{% endif %}</span>
    <span class="label label--small">{% if card.price_eur %}{{ card.price_eur }} &euro;{% else %}&mdash; &euro;{% endif %} &middot; {{ card.rarity | capitalize }}</span>
  </div>
</div>

<div class="title_bar">
  <span class="title">{{ set_name }}</span>
</div>
