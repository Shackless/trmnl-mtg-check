<div class="layout layout--row layout--stretch gap--medium" style="flex: 1 1 auto; min-height: 0">
  <div style="height: 100%; display: flex; align-items: center">
    <img class="image image-dither" src="{{ card.img }}" style="max-height: 100%; width: auto" />
  </div>
  <div style="display: flex; flex-direction: column; flex: 1 1 0; min-width: 0; height: 100%; justify-content: center">
    <div class="title title--small" data-clamp="2">{{ card.name }}</div>
    <div class="value value--xxsmall" data-clamp="2">{{ card.type }}{% if card.pt != "" %} &middot; {{ card.pt }}{% endif %}{% if card.mana != "" %} &middot; {{ card.mana }}{% endif %}</div>
    <div class="value value--xxsmall lg:mt--5" style="display: block">{% if card.price_eur %}{{ card.price_eur }} &euro;{% else %}&mdash; &euro;{% endif %} &middot; {{ card.rarity | capitalize }}</div>
  </div>
</div>

<div class="title_bar">
  <span class="title">{{ set_name }}</span>
</div>
