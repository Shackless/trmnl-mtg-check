<div class="layout layout--col gap--small h--full flex flex--col">
  <div class="flex flex--center-y flex--center-x w--full stretch" style="min-height: 0">
    <img class="image image-dither" src="{{ card.img }}" style="max-height: 100%; max-width: 100%; width: auto" />
  </div>
  <div class="w--full text--center no-shrink">
    <div class="title title--small" data-clamp="2">{{ card.name }}</div>
    <div class="value value--xxsmall" data-clamp="1">{{ card.rarity | capitalize }} #{{ card.cn }}{% if card.pt != "" %} &middot; {{ card.pt }}{% endif %}{% if card.mana != "" %} &middot; {{ card.mana }}{% endif %}</div>
    <div class="value value--xxsmall block">{% if card.price_eur %}{{ card.price_eur }} &euro; (Cardmarket){% else %}Price from {{ release | date: "%b %d" }}{% endif %}{% if card.edhrec_fmt != "" %} &middot; EDHREC {{ card.edhrec_fmt }}{% endif %}</div>
    {% if card.buy_url != "" %}
    <div class="hidden lg:flex w--full lg:mt--10">
      <div class="stretch"></div>
      <div class="no-shrink" style="width: 100px; height: 100px">{{ card.buy_url | qr_code }}</div>
    </div>
    {% endif %}
  </div>
</div>

<div class="title_bar">
  <span class="title">{{ set_name }}</span>
  <span class="instance">{{ pos }}/{{ total }}</span>
</div>
